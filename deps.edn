{:paths ["src/clj"]

 :deps {org.clojure/clojure {:mvn/version "1.12.5"}
        org.knowm.xchart/xchart {:mvn/version "4.0.3"}
        ;; xchart 4.0.3 makes its exporters optional (no longer transitive), but
        ;; com.hypirion.clj-xchart loads them at namespace init. Pin the exporter
        ;; libs it references (versions xchart 4.0.2 bundled); pdfbox/fontbox come
        ;; in transitively via graphics2d.
        de.erichseifert.vectorgraphics2d/VectorGraphics2D {:mvn/version "0.13"}
        de.rototor.pdfbox/graphics2d {:mvn/version "3.0.5"}
        com.madgag/animated-gif-lib {:mvn/version "1.4"}}

 :aliases
 {:test
  {:extra-paths ["test" "target/classes"]
   :extra-deps {lambdaisland/kaocha {:mvn/version "1.91.1392"}
                org.slf4j/slf4j-nop {:mvn/version "2.0.18"}
                org.clojure/test.check {:mvn/version "1.1.3"}}
   :main-opts ["-m" "kaocha.runner"]}

  :1.10 {:override-deps {org.clojure/clojure {:mvn/version "1.10.3"}}}
  :1.11 {:override-deps {org.clojure/clojure {:mvn/version "1.11.4"}}}
  :1.12 {:override-deps {org.clojure/clojure {:mvn/version "1.12.5"}}}

  :build
  {:deps {io.github.clojure/tools.build {:mvn/version "0.10.14"}
          slipset/deps-deploy {:mvn/version "0.2.5"}}
   :ns-default build}}}
